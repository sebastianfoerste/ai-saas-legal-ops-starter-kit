{
  "name": "@sebastianfoerste/ai-saas-legal-ops-starter-kit",
  "version": "1.0.0",
  "type": "module",
  "description": "Portfolio-grade legal engineering starter kit for AI-native SaaS companies.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "legal-ops-demo": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "schemas",
    "examples",
    "policies",
    "templates",
    "docs",
    "README.md",
    "LICENSE",
    "sample-output.md",
    "what-this-proves.md"
  ],
  "scripts": {
    "build": "tsc",
    "check:package": "npm run build && node scripts/check-package.mjs",
    "audit:root": "npm audit --omit=dev",
    "audit:dashboard": "node scripts/check-dashboard-audit.mjs",
    "demo": "npm run build && node dist/src/cli.js",
    "demo:json": "npm run build && node dist/src/cli.js --format json",
    "dashboard:dev": "npm run build && npm --prefix dashboard run dev",
    "dashboard:lint": "npm --prefix dashboard run lint",
    "dashboard:build": "npm run build && npm --prefix dashboard run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:examples": "vitest run tests/schema-validation.test.ts"
  },
  "keywords": [
    "legalops",
    "legal-engineering",
    "saas",
    "ai-governance",
    "json-schema"
  ],
  "author": "Sebastian Förste",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
